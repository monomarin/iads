# ──────────────────────────────────────────────────
# Retail Audio Engine — Environment Variables
# ──────────────────────────────────────────────────

# Vercel
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_APP_ID=

# Database (Neon / Vercel Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/raemonorepo

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ElevenLabs TTS
ELEVENLABS_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (Email)
RESEND_API_KEY=

# n8n (self-hosted)
N8N_HOST=http://localhost:5678
N8N_API_KEY=

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
